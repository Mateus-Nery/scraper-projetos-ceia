# =====================================================================
# AplicAI — variáveis de ambiente
# Copie para .env e preencha. Nunca commite o .env real.
# =====================================================================

# ---------- Supabase ----------
# Pegue em: Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=                  # chave pública (pode ir pro frontend)
SUPABASE_SERVICE_ROLE_KEY=          # chave secreta (só backend, NUNCA exponha)

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_MODEL_MATCH=gpt-4o-mini      # ranqueamento dos top-K
OPENAI_MODEL_EMAIL=gpt-4o           # geração do rascunho de email
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# ---------- App ----------
APP_ENV=development                 # development | production
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# ---------- Limites de custo ----------
USER_MONTHLY_BUDGET_USD=0.50
GLOBAL_MONTHLY_BUDGET_USD=50.0

# ---------- Anti-spam coordenadores ----------
COORD_EMAIL_COOLDOWN_DAYS=30        # 1 email por aluno → mesmo coordenador a cada N dias
OPT_OUT_JWT_SECRET=                 # gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ---------- LGPD ----------
CV_RETENTION_DAYS=90                # apaga CV após N dias de inatividade

# ---------- Gmail API (Fase 7 — ainda não usado) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
